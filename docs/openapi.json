{
  "openapi": "3.1.0",
  "info": {
    "title": "Math API",
    "description": "\n    API REST para operaciones matemáticas y estadísticas.\n    \n    Esta API proporciona endpoints para:\n    * **Calculadora**: Operaciones matemáticas básicas (suma, resta, multiplicación, división, potencia)\n    * **Estadísticas**: Cálculos estadísticos (promedio, mediana, desviación estándar)\n    \n    ## Versiones\n    \n    ### v2.0 (Actual)\n    - Operaciones de calculadora (5 endpoints)\n    - Operaciones estadísticas (3 endpoints)\n    - Soporte para CORS\n    \n    ### v1.0 (Deprecada)\n    - Solo operaciones de calculadora\n    \n    ## Autenticación\n    \n    Esta API no requiere autenticación actualmente.\n    \n    ## Rate Limiting\n    \n    No hay límites de tasa configurados actualmente.\n    ",
    "contact": {
      "name": "Math API Team",
      "url": "https://github.com/test-repository/test",
      "email": "support@example.com"
    },
    "license": {
      "name": "MIT License",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "2.0.0"
  },
  "paths": {
    "/calculator/add": {
      "post": {
        "tags": [
          "Calculator"
        ],
        "summary": "Suma dos números",
        "description": "Realiza la suma de dos números y devuelve el resultado.",
        "operationId": "add_calculator_add_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculatorRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "El resultado de la suma",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CalculatorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
